# --- URLs / Hosts ---
OLLAMA_URL=http://localhost:11434

# Milvus
MILVUS_URI=http://127.0.0.1:19530
EMBEDDING_DIMENSION=768

# --- VDB service ---
MAX_EMB_CHARS=8000

# --- RAG service ---
MILVUS_COLLECTION=knowledge_base
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMB_MODEL=qwen3-embedding:0.6b
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-base
RERANK_URL=http://127.0.0.1:8282/rerank

TOP_K_FINAL=5
TOP_K_RECALL=60
EF_SEARCH=100
RERANK_MAX_CHARS=2000
BUILD_CONTEXT_MAX_CHARS=6000
TEMPERATURE=0.2
NUM_PREDICT=400

# --- Rerank service ---
RERANK_MODEL=BAAI/bge-reranker-base
USE_FP16=false
MAX_PASSAGES=256
MAX_TEXT_CHARS=2000

# --- Chunking service ---
DOCLING_MODELS_PATH=$HOME/.cache/docling/models
VDB_SERVICE_URL=http://localhost:8003

# --- Ingestion script ---
CHUNKING_API_URL=http://localhost:8002
VDB_COLLECTION=knowledge_base

# TEI Embedding service
TEI_ENDPOINT=http://localhost:8083

# Langfuse (leave empty to disable tracing)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=http://localhost:3000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
